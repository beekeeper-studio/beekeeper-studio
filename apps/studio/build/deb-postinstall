#! /bin/bash

OLD_FILE=/etc/apt/sources.list.d/beekeeper-studio.list

if [ -f $OLD_FILE ]; then
  echo "--> Beekeeper Studio has migrated to a new apt repo, adding it, and removing the old one"
  echo "--> For more information see https://docs.beekeeperstudio.io/installation"
  rm -f $OLD_FILE
  rm -f $OLD_FILE.save
fi

# ideally this would use a links file https://github.com/jordansissel/fpm/issues/960
if [ ! -e /usr/bin/beekeeper-studio ]; then
  ln -sf /opt/Beekeeper\ Studio/beekeeper-studio /usr/bin/beekeeper-studio
fi
