{
  "name": "bks-root",
  "version": "1.0.0",
  "repository": "git@github.com:beekeeper-studio/beekeeper-studio.git",
  "author": "Matthew Rathbone <matthew.rathbone@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "bks:build": "pnpm run lib:build && pnpm --filter beekeeper-studio run electron:build",
    "bks:dev": "pnpm run lib:build && pnpm --filter beekeeper-studio run electron:serve",
    "bks:config:build": "pnpm --filter beekeeper-studio run config:build",
    "lib:dev": "pnpm --filter @beekeeperstudio/ui-kit run lib:dev",
    "lib:build": "pnpm --filter @beekeeperstudio/ui-kit run build",
    "electron:build": "pnpm run bks:build",
    "electron:serve": "pnpm run bks:dev",
    "test:e2e": "pnpm --filter beekeeper-studio run test:e2e",
    "test:e2e:ci": "pnpm --filter beekeeper-studio run test:e2e:ci",
    "test:integration": "pnpm --filter beekeeper-studio run test:integration",
    "test:unit": "pnpm --filter beekeeper-studio run test:unit && pnpm --filter @beekeeperstudio/ui-kit run test",
    "test:ci": "pnpm --filter beekeeper-studio run test:ci",
    "test:codemirror": "pnpm --filter beekeeper-studio run test:codemirror",
    "all:lint": "pnpm --filter beekeeper-studio run lint",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "devDependencies": {
    "husky": "8.0.3",
    "pinst": "^3.0.0"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
